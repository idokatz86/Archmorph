# Archmorph Backend — Environment Variables
# Copy this file to .env and fill in real values.

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API Authentication
ARCHMORPH_API_KEY=your-api-key-here
ARCHMORPH_ADMIN_KEY=your-admin-key-here

# GitHub Integration (for chatbot issue creation)
GITHUB_TOKEN=your-github-token
GITHUB_REPO=your-org/your-repo

# Environment
ENVIRONMENT=development

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.azurestaticapps.net
