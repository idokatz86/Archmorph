# ─────────────────────────────────────────────────────────────
# Archmorph — Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ============================================
# REQUIRED — Azure OpenAI (core functionality)
# ============================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Legacy alias (same as AZURE_OPENAI_KEY)
# AZURE_OPENAI_API_KEY=

# ============================================
# REQUIRED — Azure Storage (diagram uploads)
# ============================================
# Use connection string OR account URL (managed identity)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_ACCOUNT_URL=https://youraccount.blob.core.windows.net

# ============================================
# REQUIRED — Azure Identity
# ============================================
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# ============================================
# DATABASE — PostgreSQL (production) / SQLite (dev)
# ============================================
# Omit for SQLite default: sqlite:///./archmorph.db
# DATABASE_URL=postgresql://user:password@localhost:5432/archmorph
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=3600
# DB_ECHO=false

# ============================================
# AUTHENTICATION — Azure AD B2C
# ============================================
# JWT_SECRET must be set in production/staging.
# JWT_SECRET=replace-with-strong-random-secret
# TRUST_SWA_PRINCIPAL_HEADER=true only if the backend is reachable exclusively through a validated SWA-linked ingress.
# AZURE_AD_B2C_TENANT=your-tenant
# AZURE_AD_B2C_CLIENT_ID=your-client-id
# AZURE_AD_B2C_POLICY=B2C_1_signupsignin

# ============================================
# ADMIN — API key for admin endpoints
# ============================================
# ARCHMORPH_ADMIN_KEY=your-admin-secret-key
# ARCHMORPH_API_KEY=your-api-key
# ADMIN_SESSION_TTL_MINUTES=60

# ============================================
# REDIS — Session store & caching
# ============================================
# REDIS_URL=redis://localhost:6379/0
# REDIS_MAX_CONNECTIONS=10
# REDIS_SOCKET_TIMEOUT=5

# ============================================
# SESSION — File-based fallback (if no Redis)
# ============================================
# SESSION_FILE_DIR=./sessions

# ============================================
# STRIPE — Billing integration (#144)
# ============================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# STRIPE_SUCCESS_URL=https://yourapp.com/success
# STRIPE_CANCEL_URL=https://yourapp.com/cancel
# STRIPE_METER_ANALYSIS=meter_analysis
# STRIPE_METER_HLD=meter_hld
# STRIPE_METER_IAC=meter_iac

# ============================================
# GITHUB — OAuth & repo integration
# ============================================
# GITHUB_TOKEN=ghp_...
# GITHUB_CLIENT_ID=your-github-oauth-client-id
# GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
# GITHUB_REPO=owner/repo

# ============================================
# OBSERVABILITY — Azure Monitor / App Insights
# ============================================
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
# ENABLE_TELEMETRY=true
# LOG_LEVEL=INFO

# ============================================
# CORS — Allowed origins (comma-separated)
# ============================================
# ALLOWED_ORIGINS=http://localhost:5173,https://yourapp.com

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development

# ============================================
# PERFORMANCE TUNING
# ============================================
# CONCURRENT_REQUESTS=50
# MAX_UPLOAD_SIZE=10485760
# GZIP_MINIMUM_SIZE=500
# THREAD_POOL_SIZE=4
# CPU_THRESHOLD=80

# Uvicorn / Gunicorn
# WEB_CONCURRENCY=4
# UVICORN_WORKERS=4
# WORKER_CLASS=uvicorn.workers.UvicornWorker
# WORKER_TIMEOUT=120
# KEEP_ALIVE=5
# MAX_REQUESTS=1000
# MAX_REQUESTS_JITTER=50
# MIN_REPLICAS=1
# MAX_REPLICAS=10

# ============================================
# CACHE — TTLs and sizes
# ============================================
# CACHE_TTL_ANALYSIS=3600
# CACHE_TTL_MAPPINGS=86400
# CACHE_TTL_PRICING=1800
# CACHE_MAX_SIZE=1000
# GPT_CACHE_TTL_SECONDS=3600
# GPT_CACHE_MAX_SIZE=500
# PRICING_CACHE_TTL_SECONDS=1800

# ============================================
# RATE LIMITING
# ============================================
# RATE_LIMIT_ENABLED=true

# ============================================
# AUDIT LOGGING
# ============================================
# AUDIT_LOG_ENABLED=true
# AUDIT_LOG_FILE=audit.log
# AUDIT_LOG_MAX_ENTRIES=10000
# AUDIT_BUSINESS_HOURS_START=8
# AUDIT_BUSINESS_HOURS_END=18
# AUDIT_FAILED_LOGIN_THRESHOLD=5
# AUDIT_FAILED_LOGIN_WINDOW=300
# AUDIT_BULK_EXPORT_THRESHOLD=100
# AUDIT_BULK_EXPORT_WINDOW=3600

# ============================================
# FEATURE FLAGS
# ============================================
# FEATURE_FLAGS_JSON={"dark_mode": true, "beta_features": false}

# ============================================
# COMPLIANCE (GDPR)
# ============================================
# COMPANY_NAME=Your Company
# COMPANY_EMAIL=contact@yourcompany.com
# DPO_EMAIL=dpo@yourcompany.com

# ============================================
# TERRAFORM CLI (optional — IaC preview)
# ============================================
# ARCHMORPH_ALLOW_TERRAFORM_CLI=false
