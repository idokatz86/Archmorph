{
  "name": "archmorph",
  "version": "3.6.0",
  "description": "AI-Powered Cloud Architecture Translator to Azure",
  "private": true,
  "scripts": {
    "test:backend": "cd backend && python3 -m pytest -q",
    "test:frontend": "cd frontend && npx vitest run",
    "test:e2e": "npx playwright test",
    "test": "npm run test:backend && npm run test:frontend",
    "lint:backend": "cd backend && ruff check .",
    "lint": "npm run lint:backend",
    "dev:backend": "cd backend && uvicorn main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build"
  },
  "keywords": ["azure", "cloud", "architecture", "migration", "terraform", "bicep"],
  "author": "idokatz86",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "puppeteer": "^24.37.5"
  }
}
