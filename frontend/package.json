{
  "name": "archmorph-frontend",
  "private": true,
  "version": "3.9.0",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md}\"",
    "generate:api-types": "openapi-typescript ../backend/openapi.json -o src/generated/api-types.d.ts",
    "generate:api-paths": "node scripts/generate-api-paths.mjs ../backend/openapi.json src/generated/api-paths.js",
    "generate:api-artifacts": "npm run generate:api-types && npm run generate:api-paths",
    "generate:api-schema": "cd ../backend && python3 export_openapi.py > openapi.json && cd ../frontend && npm run generate:api-artifacts",
    "check:api-drift": "npm run generate:api-artifacts && git diff --exit-code -- src/generated/api-types.d.ts src/generated/api-paths.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/dagre": "^0.7.54",
    "@xyflow/react": "^12.11.0",
    "dagre": "^0.8.5",
    "dompurify": "^3.4.12",
    "lucide-react": "^1.17.0",
    "prismjs": "^1.29.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.8.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "@redocly/openapi-core": "1.34.7",
    "js-yaml": "^4.2.0",
    "undici": "^7.28.0"
  }
}
