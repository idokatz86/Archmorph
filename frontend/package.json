{
  "name": "archmorph-frontend",
  "private": true,
  "version": "4.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md}\"",
    "generate:api-types": "openapi-typescript ../backend/openapi.json -o src/generated/api-types.d.ts",
    "generate:api-schema": "cd ../backend && python3 export_openapi.py > openapi.json && cd ../frontend && npm run generate:api-types"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/dagre": "^0.7.54",
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "dompurify": "^3.3.3",
    "lucide-react": "^1.8.0",
    "posthog-js": "^1.372.2",
    "prismjs": "^1.29.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "openapi-typescript": "^7.8.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
