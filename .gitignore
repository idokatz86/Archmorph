# Secrets & credentials
# Block unqualified terraform.tfvars (may contain secrets).
# Named variants (*.example, *.prod, *.staging) are safe placeholder files.
terraform.tfvars
*.tfvars.secret
# Generated by scripts/dump_configs.py — lives in ~/.config/archmorph/, never here.
# (Listed defensively in case someone accidentally copies it into the repo.)
terraform.*.tfvars
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.cert
credentials.json
service-account*.json
*.keystore

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
dist/
build/
.coverage
htmlcov/
*.db

# Node
node_modules/
npm-debug.log
yarn-error.log

# Build outputs
/frontend/dist/
/backend/dist/
backend/openapi.json
test-results/
playwright-report/
backend/data/

