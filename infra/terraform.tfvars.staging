# Staging Environment Terraform Variables
# Copy to terraform.tfvars for staging deployment

subscription_id  = "00000000-0000-0000-0000-000000000000"
environment      = "staging"
location         = "westeurope"
openai_location  = "eastus"

db_admin_username = "archmorph_staging_admin"
db_admin_password = "CHANGE_ME_STAGING_PASSWORD_MIN16"

alert_email  = "alerts@archmorph.dev"
frontend_url = "https://staging.archmorph.dev"

redis_capacity = 0  # Basic C0 for staging

enable_dr = false  # No DR for staging
