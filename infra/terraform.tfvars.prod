# Production Environment Terraform Variables
# Copy to terraform.tfvars for production deployment

subscription_id  = "00000000-0000-0000-0000-000000000000"
environment      = "prod"
location         = "westeurope"
openai_location  = "eastus"

db_admin_username = "archmorph_prod_admin"
db_admin_password = "CHANGE_ME_PRODUCTION_PASSWORD_MIN16"

alert_email  = "ops@archmorph.dev"
frontend_url = "https://app.archmorph.dev"

redis_capacity = 1  # Standard C1 for production (1GB)

enable_redis_private_endpoint   = true  # Required: prod Redis disables public access
enable_storage_private_endpoint = true  # Required: prod storage uses deny-by-default firewall

enable_dr = true  # Enable disaster recovery
